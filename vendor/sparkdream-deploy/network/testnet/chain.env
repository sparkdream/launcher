# deploy/config/network/testnet/chain.env
#
# Network-specific variables. Source this file in scripts
# to avoid hardcoding chain parameters.
#
# Usage: source deploy/config/network/testnet/chain.env

CHAIN_ID="sparkdream-test-1"
DENOM="uspark.sparkdreamtest"
MIN_GAS_PRICES="25000uspark.sparkdreamtest"
SNAPSHOT_INTERVAL=1000
SNAPSHOT_KEEP_RECENT=2
NODE_HOME="/root/.sparkdream"
BINARY="sparkdreamd"

# Peer configuration (set per-node)
VALIDATOR_NODE_ID=""
VALIDATOR_HOST=""
VALIDATOR_PORT=""
SENTRY_NODE_ID=""
SENTRY_HOST=""
SENTRY_PORT=""
